{
  "name": "boilerplate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:prod": "npm run decrypt-prod && npm run dev",
    "dev:beta": "npm run decrypt-beta && npm run dev",
    "dev:staging": "npm run decrypt-staging && npm run dev",
    "build": "next build",
    "build:prod": "npm run decrypt-prod && next build && npm run build-sitemap",
    "build:beta": "npm run decrypt-beta && next build && npm run build-sitemap",
    "build:staging": "npm run decrypt-staging && next build && npm run build-sitemap",
    "start": "next start",
    "lint": "next lint",
    "encrypt-prod": "cm-env encrypt prod",
    "decrypt-prod": "cm-env decrypt prod",
    "encrypt-staging": "cm-env encrypt staging",
    "decrypt-staging": "cm-env decrypt staging",
    "encrypt-beta": "cm-env encrypt beta",
    "decrypt-beta": "cm-env decrypt beta",
    "encrypt-dev": "cm-env encrypt dev",
    "decrypt-dev": "cm-env decrypt dev",
    "test-all": "npm run lint && npm run build:staging",
    "build-sitemap": "next-sitemap",
    "prepare": "husky",
    "generate-types": "graphql-codegen",
    "npmrc-replace-env": "npmrc-replace-env"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^2.1.2",
    "@ant-design/icons": "^6.2.3",
    "@ant-design/nextjs-registry": "^1.3.0",
    "@apollo/client": "^4.1.9",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "antd": "^6.4.2",
    "classnames": "^2.5.1",
    "deepmerge": "^4.3.1",
    "graphql": "^16.14.0",
    "lodash.isequal": "^4.5.0",
    "next": "^15.5.12",
    "pluralize": "^8.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "universal-cookie": "^8.1.2"
  },
  "devDependencies": {
    "@commutatus/cm-env": "^1.1.0",
    "@eslint/eslintrc": "^3",
    "@graphql-codegen/cli": "^5.0.4",
    "@graphql-codegen/typescript": "^4.1.3",
    "@graphql-codegen/typescript-operations": "^4.4.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/lodash.isequal": "^4.5.8",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "15.3.2",
    "husky": "^9.1.7",
    "next-sitemap": "^4.2.3",
    "npmrc-replace-env": "^1.1.4",
    "sass": "^1.99.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5"
  }
}
